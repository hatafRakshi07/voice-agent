# ─────────────────────────────────────────────────────────────
# .env.example  —  Self-Hosted AI Voice Agent  (no external APIs)
#
# Copy:  cp .env.example .env
# All values have safe defaults; only WHISPER_MODEL and OLLAMA_MODEL
# typically need customising.
# ─────────────────────────────────────────────────────────────

# ── Local STT (faster-whisper) ────────────────────────────────
# tiny | base | small | medium | large-v3
# "base" = good balance of speed and accuracy on CPU
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Local LLM (Ollama) ────────────────────────────────────────
# Run Ollama first:  ollama serve
# Pull a model:      ollama pull llama3
# Docker service name is "ollama"
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3

# ── Local TTS (Coqui XTTS-v2) ────────────────────────────────
# After cloning a voice, paste the returned voice_id here
LOCAL_DEFAULT_VOICE_ID=
TTS_LANGUAGE=en

# ── Agent persona ─────────────────────────────────────────────
AGENT_NAME=Nova
AGENT_SYSTEM_PROMPT=You are Nova, a warm and knowledgeable AI voice assistant. Keep responses concise and conversational — you are speaking aloud, not writing. Use short sentences. Be helpful and friendly.
MAX_CONVERSATION_TURNS=20

# ── MongoDB (optional) ───────────────────────────────────────
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=voice_agent

# ── App ───────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
BASE_URL=http://localhost:8000
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://frontend:3000"]
