# ─────────────────────────────────────────────────────────────
# .env.example  —  Self-Hosted AI Voice Agent
#
# Copy to .env:   cp .env.example .env
# All defaults work out of the box with Docker Compose (Ollama mode).
# ─────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────
# "ollama"  → local Ollama (free, offline, default)
# "gemini"  → Google Gemini API (free tier, requires GEMINI_API_KEY)
LLM_PROVIDER=ollama

# ── Google Gemini (only if LLM_PROVIDER=gemini) ───────────────
# Free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Local LLM: Ollama (only if LLM_PROVIDER=ollama) ──────────
# Run:  docker compose up -d ollama
#       docker exec -it voice_agent_ollama ollama pull llama3
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=400

# ── Local STT: faster-whisper ─────────────────────────────────
# Model sizes: tiny | base | small | medium | large-v3
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CUSTOM_MODEL_PATH=

# ── Local TTS: Coqui XTTS-v2 ─────────────────────────────────
LOCAL_DEFAULT_VOICE_ID=
TTS_LANGUAGE=en
# Path to a reference WAV for default voice (optional)
VOICE_SAMPLE_PATH=

# ── Telephony Provider ────────────────────────────────────────
# "asterisk" — Asterisk PBX via FastAGI (default)
# "android"  — Android SIM gateway via WebSocket
# "twilio"   — Twilio (stub, not yet implemented)
TELEPHONY_PROVIDER=asterisk

# ── Asterisk FastAGI ──────────────────────────────────────────
FASTAGI_ENABLED=true
FASTAGI_HOST=0.0.0.0
FASTAGI_PORT=4573

# ── Android SIM Gateway ───────────────────────────────────────
ANDROID_GATEWAY_SECRET=
ANDROID_GATEWAY_URL=

# ── Silero VAD ────────────────────────────────────────────────
# true = neural Silero VAD (more accurate, needs: pip install silero-vad)
# false = WebRTC VAD (default, no extra dependencies)
USE_SILERO_VAD=false
SILERO_VAD_THRESHOLD=0.5

# ── Agent persona ─────────────────────────────────────────────
AGENT_NAME=Nova
AGENT_SYSTEM_PROMPT=You are Nova, a warm and knowledgeable AI voice assistant. Keep responses concise and conversational — you are speaking aloud, not writing. Use short sentences. Be helpful and friendly.
MAX_CONVERSATION_TURNS=20

# ── App ───────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
BASE_URL=http://localhost:8000
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://frontend:3000"]

# ── Database ──────────────────────────────────────────────────
SQLITE_PATH=data/voice_agent.db
RECORDINGS_DIR=recordings
