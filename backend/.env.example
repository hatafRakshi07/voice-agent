# ──────────────────────────────────────────────────
# OpenAI
# ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# ──────────────────────────────────────────────────
# Deepgram  (Speech-to-Text)
# ──────────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key

# ──────────────────────────────────────────────────
# ElevenLabs  (Text-to-Speech / Voice Cloning)
# ──────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Default voice ID – change to your cloned voice ID
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ──────────────────────────────────────────────────
# Twilio  (Phone / Media Streams)
# ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ──────────────────────────────────────────────────
# MongoDB
# ──────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=voice_agent

# ──────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# Public URL that Twilio can reach (use ngrok for dev)
BASE_URL=https://your-ngrok-or-domain.com
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ──────────────────────────────────────────────────
# AI Agent Personality
# ──────────────────────────────────────────────────
AGENT_NAME=Alex
AGENT_SYSTEM_PROMPT=You are Alex, a professional and friendly AI voice assistant. You handle incoming phone calls and help callers with their questions. Keep responses concise and natural for spoken conversation — avoid bullet points, markdown, or long lists. Be warm, empathetic, and helpful. If you do not know something, be honest about it. Always respond in plain spoken English.
MAX_CONVERSATION_TURNS=20
