# ─────────────────────────────────────────────────────────────
# .env.example  —  Self-Hosted AI Voice Agent  (fully offline, no external APIs)
#
# Copy to .env:   cp .env.example .env
# All defaults work out of the box with Docker Compose.
# ─────────────────────────────────────────────────────────────

# ── Local STT: faster-whisper ─────────────────────────────────
# Model sizes: tiny | base | small | medium | large-v3
# "base" = good balance of speed and accuracy on CPU
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# Optional: absolute path to a fine-tuned CTranslate2 model directory
# Leave empty to use the standard Whisper model above
WHISPER_CUSTOM_MODEL_PATH=

# ── Local LLM: Ollama ────────────────────────────────────────
# Run Ollama first:  ollama serve
# Pull a model:      ollama pull llama3
# Docker service name is "ollama"; outside Docker use http://localhost:11434
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=400

# ── Local TTS: Coqui XTTS-v2 ─────────────────────────────────
# After cloning a voice in the UI, paste the returned voice_id here
LOCAL_DEFAULT_VOICE_ID=
TTS_LANGUAGE=en

# ── Agent persona ─────────────────────────────────────────────
AGENT_NAME=Nova
AGENT_SYSTEM_PROMPT=You are Nova, a warm and knowledgeable AI voice assistant. Keep responses concise and conversational — you are speaking aloud, not writing. Use short sentences. Be helpful and friendly.
MAX_CONVERSATION_TURNS=20

# ── MongoDB (optional — app works without it) ────────────────
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=voice_agent

# ── App ───────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
BASE_URL=http://localhost:8000
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://frontend:3000"]
